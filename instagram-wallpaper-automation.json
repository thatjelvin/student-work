              "type": "string"
            },
            {
              "id": "final-theme",
              "name": "theme",
              "value": "={{ $('Prepare Memory Update').first().json.latestTheme.theme }}",
              "type": "string"
            },
            {
              "id": "final-date",
              "name": "date",
              "value": "={{ $('Prepare Memory Update').first().json.latestTheme.date }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "success-output-020",
      "name": "Success Output",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [4180, 100]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "fail-status",
              "name": "status",
              "value": "failed",
              "type": "string"
            },
            {
