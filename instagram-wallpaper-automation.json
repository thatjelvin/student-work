              "value": "={{ $json.totalFound }}",
              "type": "number"
            }
          ]
        },
        "options": {}
      },
      "id": "fail-images-021",
      "name": "Fail - Not Enough Images",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [1760, 400]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "fail-upload-status",
              "name": "status",
